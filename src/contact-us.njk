---
layout: layouts/base.njk
permalink: /contact-us/index.html
title: Contact Us
metaTitle: "Contact Us — Free Fit-Out Quotes, Chester | Direct Interiors"
metaDesc: "Get a free quote or book a no-obligation consultation for your fit-out or refurbishment. Call 01244 810 222 — covering Chester, Deeside, North Wales and the North West."
heroImage: "slider04.jpg"
heroAlt: "Direct Interiors completed commercial interior"
ogImage: "slider04.jpg"
breadcrumbs:
  - label: "Home"
    url: "/"
  - label: "Contact Us"
---
{% set heroTitle = "Contact Us" %}
{% include "components/hero.njk" %}

<section class="section">
  <div class="container contact-layout">
    <div class="contact-layout__form">
      <div class="flow measure">
        <p class="lead-first">Whether you need a free quote, a no-obligation consultation, or you’re submitting a tender enquiry — fill in the form below and we’ll get back to you as soon as possible. Prefer to talk? We do too: call us on <a href="{{ site.phoneHref }}">{{ site.phoneDisplay }}</a>.</p>
      </div>
      <div class="section__spacer"></div>
      {% include "components/enquiry-form.njk" %}
    </div>
    <aside class="contact-layout__details">
      <h2>Find us</h2>
      <address class="contact-details">
        <p><strong>{{ site.shortName }}</strong><br>
        {{ site.address.street }},<br>
        {{ site.address.locality }}, {{ site.address.town }},<br>
        {{ site.address.county }} {{ site.address.postcode }}</p>
        <p>
          <a href="{{ site.phoneHref }}">T: {{ site.phoneDisplay }}</a><br>
          <a href="mailto:{{ site.email }}">E: {{ site.email }}</a>
        </p>
      </address>
      {%- if site.openingHours %}
      <p><strong>Opening hours:</strong> {{ site.openingHours }}</p>
      {%- endif %}
      <p class="contact-details__areas">Covering {{ site.areasCovered }}.</p>
      <div class="contact-map">
        <iframe title="Map showing Direct Interiors at {{ site.addressFull }}"
                src="https://www.google.com/maps?q=96+Welsh+Road,+Garden+City,+Deeside+CH5+2HX&output=embed"
                width="400" height="300" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen></iframe>
      </div>
    </aside>
  </div>
</section>

{% set testimonialId = "golden-fish" %}
{% include "components/testimonial.njk" %}
