<footer class="site-footer">
  <div class="container site-footer__grid">
    <div class="site-footer__col">
      <h2 class="site-footer__heading">Contact</h2>
      <address class="site-footer__address">
        {{ site.address.street }},<br>
        {{ site.address.locality }}, {{ site.address.town }},<br>
        {{ site.address.county }} {{ site.address.postcode }}
      </address>
      <p>
        <a href="{{ site.phoneHref }}">T: {{ site.phoneDisplay }}</a><br>
        <a href="mailto:{{ site.email }}">E: {{ site.email }}</a>
      </p>
      {%- if site.openingHours %}
      <p>{{ site.openingHours }}</p>
      {%- endif %}
      <p class="site-footer__areas">Areas we cover: {{ site.areasCovered }}.</p>
    </div>
    <div class="site-footer__col">
      <h2 class="site-footer__heading">Solutions</h2>
      <ul class="site-footer__links">
        {%- for s in solutions %}
        <li><a href="/{{ s.slug }}">{{ s.navLabel }}</a></li>
        {%- endfor %}
      </ul>
    </div>
    <div class="site-footer__col">
      <h2 class="site-footer__heading">Company</h2>
      <ul class="site-footer__links">
        <li><a href="/about-us">About Us</a></li>
        <li><a href="/our-work">Our Work</a></li>
        <li><a href="/sub-services">Sub Services</a></li>
        <li><a href="/solutions">All Solutions</a></li>
        <li><a href="/contact-us">Contact Us</a></li>
        <li><a href="{{ site.ceilingsDirect.store }}" rel="noopener" target="_blank">Shop at Ceilings Direct</a></li>
      </ul>
    </div>
    <div class="site-footer__col">
      <h2 class="site-footer__heading">Legal</h2>
      <ul class="site-footer__links">
        <li><a href="/terms-and-conditions">Terms &amp; Conditions</a></li>
        <li><a href="/privacy-policy">Privacy Policy</a></li>
        <li><a href="/cookies-policy">Cookies Policy</a></li>
      </ul>
    </div>
  </div>
  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <p>&copy; Copyright {{ buildYear }} {{ site.footerName }}. All Rights Reserved.{% if site.companyRegNumber %} Registered in England &amp; Wales No. {{ site.companyRegNumber }}.{% endif %}</p>
      <p><a href="https://www.h10marketing.co.uk/" rel="noopener" target="_blank">Website Design: H10 Marketing</a></p>
    </div>
  </div>
</footer>
