{# Neat single contact strip — replaces the old "T -"/"E-" fragments. #}
<div class="contact-strip">
  <p class="contact-strip__label">For a free quotation:</p>
  <p class="contact-strip__details">
    <a href="{{ site.phoneHref }}">T: {{ site.phoneDisplay }}</a>
    <span class="contact-strip__sep" aria-hidden="true">&middot;</span>
    <a href="mailto:{{ site.email }}">E: {{ site.email }}</a>
  </p>
</div>
