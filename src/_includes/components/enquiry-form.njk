{# Shared enquiry form. The "What do you need?" select replaces the four old
   duplicate enquiry pages; ?enquiry=quote|consultation|tender|general pre-selects. #}
<form class="enquiry-form" id="enquiry-form" method="post"
      action="{{ site.formEndpoint or '#enquiry-form' }}"
      {% if not site.formEndpoint %}data-no-endpoint="true"{% endif %} novalidate>
  <div class="enquiry-form__row">
    <div class="enquiry-form__field">
      <label for="ef-name">Name <span class="enquiry-form__required" aria-hidden="true">*</span></label>
      <input id="ef-name" name="name" type="text" autocomplete="name" required aria-describedby="ef-name-error">
      <p class="enquiry-form__error" id="ef-name-error" hidden>Please enter your name.</p>
    </div>
    <div class="enquiry-form__field">
      <label for="ef-company">Company</label>
      <input id="ef-company" name="company" type="text" autocomplete="organization">
    </div>
  </div>
  <div class="enquiry-form__row">
    <div class="enquiry-form__field">
      <label for="ef-email">Email <span class="enquiry-form__required" aria-hidden="true">*</span></label>
      <input id="ef-email" name="email" type="email" autocomplete="email" required aria-describedby="ef-email-error">
      <p class="enquiry-form__error" id="ef-email-error" hidden>Please enter a valid email address.</p>
    </div>
    <div class="enquiry-form__field">
      <label for="ef-phone">Phone</label>
      <input id="ef-phone" name="phone" type="tel" autocomplete="tel">
    </div>
  </div>
  <div class="enquiry-form__field">
    <label for="ef-enquiry">What do you need?</label>
    <select id="ef-enquiry" name="enquiry">
      <option value="quote">A free quote</option>
      <option value="consultation">A no-obligation consultation</option>
      <option value="tender">Tender enquiry</option>
      <option value="general">General enquiry</option>
    </select>
  </div>
  <div class="enquiry-form__field">
    <label for="ef-message">Message <span class="enquiry-form__required" aria-hidden="true">*</span></label>
    <textarea id="ef-message" name="message" rows="6" required aria-describedby="ef-message-error"></textarea>
    <p class="enquiry-form__error" id="ef-message-error" hidden>Please tell us a little about your project or enquiry.</p>
  </div>
  <div class="enquiry-form__field enquiry-form__field--consent">
    <input id="ef-consent" name="consent" type="checkbox" required aria-describedby="ef-consent-error">
    <label for="ef-consent">I agree to Direct Interiors contacting me about this enquiry using the details I have supplied, as described in the <a href="/privacy-policy">privacy policy</a>. <span class="enquiry-form__required" aria-hidden="true">*</span></label>
    <p class="enquiry-form__error" id="ef-consent-error" hidden>Please confirm you are happy for us to contact you.</p>
  </div>
  <p class="enquiry-form__status" role="status" aria-live="polite" data-success="Thank you for contacting us. We will get back to you as soon as possible." data-error="Oops, there was an error sending your message. Please try again later, or call us on {{ site.phoneDisplay }}."></p>
  <button class="btn btn--primary" type="submit">Send enquiry</button>
  {%- if not site.formEndpoint %}
  <p class="enquiry-form__fallback">Prefer to talk? Call <a href="{{ site.phoneHref }}">{{ site.phoneDisplay }}</a> or email <a href="mailto:{{ site.email }}">{{ site.email }}</a>.</p>
  {%- endif %}
</form>
