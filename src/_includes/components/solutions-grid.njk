{# Shared services card grid (Home + /solutions hub). Whole-card links, equal heights. #}
<div class="card-grid card-grid--3">
  {%- for s in solutions %}
  <article class="card">
    <div class="card__media">
      {% image s.cardImage, s.cardAlt, { widths: [400, 800], sizes: "(min-width: 1024px) 400px, (min-width: 640px) 50vw, 100vw" } %}
    </div>
    <div class="card__body">
      <h3 class="card__title"><a class="card__link" href="/{{ s.slug }}">{{ s.cardTitle }}</a></h3>
      <p class="card__blurb">{{ s.cardBlurb }}</p>
      <p class="card__more" aria-hidden="true">Learn more <span>&rarr;</span></p>
    </div>
  </article>
  {%- endfor %}
</div>
