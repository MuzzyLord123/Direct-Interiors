<header class="site-header" id="site-header">
  <div class="top-bar">
    <div class="container top-bar__inner">
      <p class="top-bar__contact">
        <a href="{{ site.phoneHref }}" class="top-bar__phone">T: {{ site.phoneDisplay }}</a>
        <a href="mailto:{{ site.email }}" class="top-bar__email">{{ site.email }}</a>
      </p>
      <a class="top-bar__sister" href="{{ site.ceilingsDirect.url }}" rel="noopener" target="_blank">Visit Ceilings Direct <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
  <div class="site-header__main">
    <div class="container site-header__inner">
      <a class="site-header__logo" href="/" aria-label="{{ site.shortName }} — home">
        {% image "logo-cd2.png", "Direct Interiors North West Limited — incorporating Ceilings Direct and Direct Shopfitting & Interiors", { widths: [240, 480], sizes: "240px", eager: true, class: "site-header__logo-img" } %}
      </a>
      <nav class="site-nav" id="site-nav" aria-label="Main">
        <button class="site-nav__toggle" type="button" aria-expanded="false" aria-controls="site-nav-list">
          <span class="site-nav__toggle-box" aria-hidden="true"><span></span><span></span><span></span></span>
          <span class="site-nav__toggle-label">Menu</span>
        </button>
        <ul class="site-nav__list" id="site-nav-list">
          {%- for item in navigation.primary %}
          {%- if item.children %}
          <li class="site-nav__item site-nav__item--has-children">
            <a href="{{ item.url }}"{% if page.url == item.url + "/" %} aria-current="page"{% endif %}>{{ item.label }}</a>
            <button class="site-nav__disclosure" type="button" aria-expanded="false" aria-label="Show {{ item.label }} pages">
              <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true" focusable="false"><path d="M2 4l4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
            <ul class="site-nav__dropdown">
              {%- for child in item.children %}
              <li><a href="{{ child.url }}"{% if page.url == child.url + "/" %} aria-current="page"{% endif %}>{{ child.label }}</a></li>
              {%- endfor %}
            </ul>
          </li>
          {%- else %}
          <li class="site-nav__item">
            <a href="{{ item.url }}"{% if page.url == item.url + "/" or (item.url == "/" and page.url == "/") %} aria-current="page"{% endif %}>{{ item.label }}</a>
          </li>
          {%- endif %}
          {%- endfor %}
          <li class="site-nav__item site-nav__item--cta">
            <a class="btn btn--primary btn--small" href="/contact-us?enquiry=quote">Get a free quote</a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>
