{
  "name": "direct-interiors",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Direct Interiors North West — premium marketing site (React + Vite).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && vite build --ssr src/entry-server.tsx --outDir dist-server --emptyOutDir && node scripts/prerender-ssg.mjs",
    "typecheck": "tsc --noEmit",
    "build:novite": "vite build",
    "preview": "vite preview --port 4173",
    "images": "node scripts/generate-images.mjs",
    "prerender": "node scripts/prerender-ssg.mjs",
    "check:placeholders": "node scripts/check-placeholders.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check": "node scripts/check-placeholders.mjs && node scripts/check-links.mjs",
    "verify": "npm run build && npm run check"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.2",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "sharp": "^0.33.5",
    "sirv": "^3.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
